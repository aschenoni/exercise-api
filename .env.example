# Monetization surfaces (PRODUCT.md §6.5) — all optional; features render
# nothing when unset. Values live in Vercel project env, not in git.

# Buy Me a Coffee page — enables ☕ links in header + footer.
NEXT_PUBLIC_COFFEE_URL=https://buymeacoffee.com/exercise.api

# Ad network — enables the ad slot in the pricing section.
# Supported values (see docs/ADS-SETUP.md): ethicalads
# NEXT_PUBLIC_AD_PROVIDER=
# NEXT_PUBLIC_AD_PUBLISHER_ID=

# Rate limiting store (optional). When unset, limiting is best-effort
# in-memory per instance. Provision Upstash Redis (Vercel Marketplace)
# for accurate cross-instance limits.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
